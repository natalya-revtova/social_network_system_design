// 1. БД для хранения картинок: blob-storage.
// 2. БД для хранения пользователей, постов, сообщений: реляционная БД.

Table subscriptions {
  id integer [primary key]
  following_user_id integer [ ref:  > users.id ]
  followed_user_id integer [ ref:  > users.id ]
  created_at timestamp
}

Table users {
  id integer [primary key]
  username varchar
  first_name varchar
  last_name varchar
  description text
  image_url varchar
  created_at timestamp
  updated_at timestamp
}

Table posts {
  id integer [primary key]
  user_id integer [ ref:  > users.id ]
  body text
  location varchar
  images_urls varchar[]
  created_at timestamp
  updated_at timestamp
}

Table comments {
  id integer [primary key]
  post_id integer [ ref:  > posts.id ]
  user_id integer [ ref:  > users.id ] 
  body text
  created_at timestamp
}

Table likes {
  id integer [primary key]
  post_id integer [ ref:  > posts.id ]
  user_id integer [ ref:  > users.id ]
  created_at timestamp
}

Table chats {
  id integer [primary key]
  title varchar
  image_url varchar
  users_ids integer[]
}

Table users_to_chats {
  chat_id integer [ ref:  > chats.id ]
  user_id integer [ ref:  > users.id ]
}

Table messages {
  id integer [primary key]
  chat_id integer [ ref:  > chats.id ]
  user_id integer [ ref:  > users.id ]
  body text
  images_urls varchar[]
  created_at timestamp
}